# Copy this file to ".env" and fill in your own secret values.
# ".env" is gitignored, so your real passwords never get committed.
#
#   PowerShell:  Copy-Item .env.example .env
#
# The admin/researcher accounts are only created if their password is set.
# JWT_SECRET signs login tokens; if you leave it blank the app generates a
# temporary one on each restart (logins won't survive a restart).

ADMIN_EMAIL=admin@rms.com
ADMIN_PASSWORD=change-me-to-a-strong-password

RESEARCHER_EMAIL=researcher@rms.com
RESEARCHER_PASSWORD=change-me-too

JWT_SECRET=put-a-long-random-string-here
